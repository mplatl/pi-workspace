# =============================================================================
# Pi Coding Agent — Environment Variables for Business Central Development
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — never commit secrets!
# =============================================================================

# --- API Keys for LLM Providers (at least one required) ---
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=...

# --- GitHub Private (mplatl) ---
# Personal access token for GitHub private repos
# Generate: https://github.com/settings/tokens → classic, repo scope
GITHUB_TOKEN=ghp_...

# --- Qdrant Vector Database ---
# URL for local or remote Qdrant instance (used by rag_index/rag_query)
# Default: http://localhost:6333
QDRANT_URL=http://localhost:6333

# Local Qdrant storage directory (make sure disk space is available)
QDRANT_STORAGE_PATH=./qdrant_storage

# --- Business Central / NAV Container ---
# Container name used by BcContainerHelper for build/test sandbox
BC_CONTAINER_NAME=bc-sandbox

# BC authentication for SaaS sandbox (Automation API v2.0)
# Service-to-service AAD app registration:
#   https://learn.microsoft.com/en-us/dynamics365/business-central/dev-itpro/administration/automation-apis
BC_TENANT_ID=00000000-0000-0000-0000-000000000000
BC_CLIENT_ID=00000000-0000-0000-0000-000000000000
BC_CLIENT_SECRET=...

# BC environment name (e.g., Sandbox, Production)
BC_ENVIRONMENT_NAME=Sandbox

# BC company name (e.g., CRONUS DE)
BC_COMPANY_NAME=CRONUS DE

# --- Docker / Container ---
# Docker host for BC containers (leave empty for local Docker Desktop)
DOCKER_HOST=

# --- Optional: Pi Agent Config ---
# Override pi config directory
# PI_CODING_AGENT_DIR=~/.pi/agent

# Disable telemetry
# PI_TELEMETRY=0

# Disable version check
# PI_SKIP_VERSION_CHECK=1

# Offline mode (disables all network)
# PI_OFFLINE=1

# Enable extended prompt caching
# PI_CACHE_RETENTION=long

# --- Build & Deploy ---
# Default BC version for builds
BC_VERSION=24

# Default BC country for builds (de, w1, at, ch, etc.)
BC_COUNTRY=de

# Output directory for compiled .app files
BC_OUTPUT_DIR=./output

# Symbols directory (.alpackages)
BC_SYMBOLS_DIR=./.alpackages
