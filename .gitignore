# =============================================================================
# .gitignore for BC AL Development + Pi Workspace
# =============================================================================

# --- Environment files with secrets ---
.env

# --- Business Central AL ---
.alpackages/
*.app
*.dll
*.pdb
.vsix/
output/
symbols/
*.zip
*.runtimeconfig.json
launch.json
rad.json

# Visual Studio Code
.vscode/
*.code-workspace

# --- Qdrant data ---
qdrant_storage/
qdrant_data/

# --- RAG cache ---
.rag_cache/

# --- Pi agent sessions (local, dont commit) ---
.pi/sessions/

# --- Node / npm ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- OS ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- Docker ---
docker-compose.override.yml

# --- PowerShell ---
*.ps1.xml
