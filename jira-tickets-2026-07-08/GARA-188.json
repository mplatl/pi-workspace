0},"breached":true,"paused":false,"withinCalendarHours":true,"goalDuration":{"millis":3600000,"friendly":"1h"},"elapsedTime":{"millis":507985018,"friendly":"141h 6m"},"remainingTime":{"millis":-504385018,"friendly":"-140h 6m"}}},"resolutiondate":null,"workratio":-1,"watches":{"self":"https://erp-jira.cegeka.com/rest/api/2/issue/GARA-188/watchers","watchCount":1,"isWatching":false},"customfield_16000":null,"created":"2026-06-11T12:12:53.000+0200","customfield_10021":null,"customfield_14502":null,"customfield_12202":null,"customfield_14503":"Support","customfield_11114":{"_links":{"jiraRest":"https://erp-jira.cegeka.com/rest/api/2/issue/654112","web":"https://erp-jira.cegeka.com/servicedesk/customer/portal/458/GARA-188","self":"https://erp-jira.cegeka.com/rest/servicedeskapi/request/654112"},"requestType":{"id":"8090","_links":{"self":"https://erp-jira.cegeka.com/rest/servicedeskapi/servicedesk/458/requesttype/8090"},"name":"Emailed request","description":"Request type for Emailed request","helpText":"Request type for Emailed request","serviceDeskId":"458","groupIds":[],"icon":{"id":"11927","_links":{"iconUrls":{"48x48":"https://erp-jira.cegeka.com/secure/viewavatar?avatarType=SD_REQTYPE&size=large&avatarId=11927","24x24":"https://erp-jira.cegeka.com/secure/viewavatar?avatarType=SD_REQTYPE&size=small&avatarId=11927","16x16":"https://erp-jira.cegeka.com/secure/viewavatar?avatarType=SD_REQTYPE&size=xsmall&avatarId=11927","32x32":"https://erp-jira.cegeka.com/secure/viewavatar?avatarType=SD_REQTYPE&size=medium&avatarId=11927"}}}},"currentStatus":{"status":"In Progress","statusDate":{"iso8601":"2026-06-27T10:19:03+0200","jira":"2026-06-27T10:19:03.000+0200","friendly":"27/Jun/26 10:19 AM","epochMillis":1782548343000}}},"customfield_10300":null,"customfield_14500":null,"customfield_16008":null,"customfield_12600":null,"customfield_11115":[],"customfield_16007":null,"customfield_11105":null,"customfield_11900":null,"customfield_13803":null,"customfield_11109":null,"updated":"2026-07-06T16:43:50.000+0200","timeoriginalestimate":null,"description":"Hallo,\r\n\r\nwir haben hier ein Problem bei der Preisberechnung von Verkaufsaufträgen festgestellt.\r\n\r\nIch habe den Ablauf in der TEST-Umgebung 1 nachgestellt. Ab hier beziehe ich mich daher auf die TEST-Umgebung. Der gleiche Fehler ist jedoch auch in der LIVE-Umgebung am 11.06.2026 aufgetreten.\r\n\r\n \r\n\r\nDas bedeutet, dass sich TEST und LIVE am 11.06.2026 um ca. 10:00 Uhr identisch verhalten haben.\r\n\r\n \r\n\r\n*Ablauf*\r\n\r\nÜber den Webshop wurden automatisch zwei Verkaufsaufträge im BC angelegt. Selber Kunde ,selbes Produkt und Beide Aufträge wurden mit einer Sollmenge von 50 t erstellt.\r\n\r\nDa wir 50 t nicht auf einmal liefern können, werden solche Aufträge üblicherweise auf 25 t reduziert und für die Restmenge wird ein weiterer Auftrag manuell angelegt.\r\n\r\nDer Fehler tritt bei den automatisch angelegten Aufträgen auf.\r\n\r\nZum Zeitpunkt der Auftragserfassung war für diesen Kunden *kein Preis hinterlegt.* Daher musste der Preis manuell eingetragen werden.\r\n\r\nDabei wurden zwei unterschiedliche Vorgehensweisen getestet:\r\n\r\n \r\n\r\n*VA26040228*\r\n\r\n* Zuerst wurde der Preis eingetragen.\r\n* Anschließend wurde die Sollmenge von 50 t auf 25 t korrigiert.\r\n* Ergebnis: *_Der Gesamtbetrag bleibt auf Basis von 50 t bestehen und wird nicht neu berechnet._*\r\n\r\n*VA26040229*\r\n\r\n* Zuerst wurde die Sollmenge von 50 t auf 25 t korrigiert.\r\n* Anschließend wurde der Preis eingetragen.\r\n* Ergebnis: Der Gesamtbetrag wird korrekt auf Basis von 25 t berechnet.\r\n\r\n \r\n\r\n*Erwartetes Verhalten*\r\n\r\nNach einer Änderung der Sollmenge sollte der Gesamtbetrag unabhängig von der Reihenfolge der Eingaben neu berechnet werden.\r\n\r\nDerzeit scheint die Neuberechnung nicht zu erfolgen, wenn zuerst der Preis eingetragen und danach die Menge geändert wird.\r\n\r\n \r\n\r\n","customfield_17600":null,"customfield_10010":null,"customfield_13401":null,"customfield_13400":null,"customfield_11500":[{"id":"417","name":"GARA","_links":{"self":"https://erp-jira.cegeka.com/rest/servicedeskapi/organization/417"}}],"customfield_11103":null,"timetracking":{},"customfield_11104":null,"customfield_13402":null,"customfield_11612":null,"customfield_11611":null,"attachment":[{"self":"https://erp-jira.cegeka.com/rest/api/2/attachment/1920865","id":"1920865","filename":"image.png","author":{"self":"https://erp-jira.cegeka.com/rest/api/2/user?username=haunschmied%40garant.co.at","name":"haunschmied@garant.co.at","key":"JIRAUSER51350","emailAddress":"haunschmied@garant.co.at","avatarUrls":{"48x48":"https://www.gravatar.com/avatar/606ca9526ab8013a12f94f28eb7d3a17?d=mm&s=48","24x24":"https://www.gravatar.com/avatar/606ca9526ab8013a12f94f28eb7d3a17?d=mm&s=24","16x16":"https://www.gravatar.com/avatar/606ca9526ab8013a12f94f28eb7d3a17?d=mm&s=16","32x32":"https://www.gravatar.com/avatar/606ca9526ab8013a12f94f28eb7d3a17?d=mm&s=32"},"displayName":"Roland Haunschmied","active":true,"timeZone":"Europe/Brussels"},"created":"2026-06-11T12:11:39.000+0200","size":496740,"mimeType":"image/png","content":"https://erp-jira.cegeka.com/secure/attachment/1920865/image.png","thumbnail":"https://erp-jira.cegeka.com/secure/thumbnail/1920865/_thumb_1920865.png"},{"self":"https://erp-jira.cegeka.com/rest/api/2/attachment/1920866","id":"1920866","filename":"image-1.png","author":{"self":"https://erp-jira.cegeka.com/rest/api/2/user?username=haunschmied%40garant.co.at","name":"haunschmied@garant.co.at","key":"JIRAUSER51350","emailAddress":"haunschmied@garant.co.at","avatarUrls":{"48x48":"https://www.gravatar.com/avatar/606ca9526ab8013a12f94f28eb7d3a17?d=mm&s=48","24x24":"https://www.gravatar.com/avatar/606ca9526ab8013a12f94f28eb7d3a17?d=mm&s=24","16x16":"https://www.gravatar.com/avatar/606ca9526ab8013a12f94f28eb7d3a17?d=mm&s=16","32x32":"https://www.gravatar.com/avatar/606ca9526ab8013a12f94f28eb7d3a17?d=mm&s=32"},"displayName":"Roland Haunschmied","active":true,"timeZone":"